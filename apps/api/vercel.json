{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-emails",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/process-message-queue",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/notify-expiring-subscriptions",
      "schedule": "0 12 * * *"
    }
  ]
}
