generator client {
  provider = "prisma-client-js"
  output   = "../apps/api/node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  logtoId           String   @unique
  email             String   @unique
  name              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  subscriptionPlanId String?
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  trialEndsAt        DateTime?
  asaasCustomerId   String?

  instances         Instance[]
  apiKeys           ApiKey[]
  dailyUsages       DailyUsage[]
}

model SubscriptionPlan {
  id                String   @id // 'free', 'basic', 'pro', 'enterprise'
  name              String
  description       String?
  priceMonthly      Decimal  @db.Decimal(10, 2) @default(0)
  priceAnnual       Decimal  @db.Decimal(10, 2) @default(0)
  
  // Limits
  messagesPerDay    Int      @default(100)
  instancesLimit    Int      @default(1)
  
  // Features
  hasWebhooks       Boolean  @default(false)
  hasTemplates      Boolean  @default(false)
  hasSmsIncluded    Boolean  @default(false)
  
  // Payment
  asaasId           String? // ID do produto no Asaas
  
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  
  users             User[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("subscription_plans")
}

model Instance {
  id                String   @id @default(uuid())
  name              String
  status            String   @default("disconnected") // disconnected, connecting, connected
  serverUrl         String?  // URL da Evolution API para esta instancia (se multi-server)
  token             String?  // Token da Evolution API
  orgId             String?
  
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ApiKey {
  id                String   @id @default(uuid())
  key               String   @unique
  name              String?
  orgId             String?
  scopes            String?
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  createdAt         DateTime @default(now())
  expiresAt         DateTime?
}

model DailyUsage {
  id        String   @id @default(uuid())
  orgId     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date // Store only the date part
  count     Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("daily_usages")
}

model WebhookConfig {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  events    String   // JSON array of event names
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookLog {
  id         String   @id @default(uuid())
  orgId      String
  webhookId  String
  event      String
  payload    String
  success    Boolean
  statusCode Int?
  error      String?
  createdAt  DateTime @default(now())
}

model Campaign {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  instanceId  String
  templateId  String?
  segmentTags String?  // JSON array of tags
  scheduledAt DateTime?
  status      String   @default("draft") // draft, scheduled, running, done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  data      String?
  createdAt DateTime @default(now())
}
model Message {
  id          String   @id @default(uuid())
  orgId       String
  instanceId  String
  to          String
  body        String
  type        String   @default("text") // text, image, audio, document
  status      String   @default("queued") // queued, sent, delivered, failed
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  body      String
  variables String?  // JSON array of variable names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  orgId     String
  name      String?
  phone     String   @unique
  tags      String?  // JSON array of strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  @@map("system_settings")
}

/// Preferências por organização (x-org-id = logto sub). Usado em envio em massa e segurança da API.
model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?

  // Tipo de desconto: ou percentOff (0-100) ou amountOff (R$ fixo). Apenas um.
  percentOff      Int?
  amountOff       Decimal? @db.Decimal(10, 2)

  // Validade
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  maxUses         Int?      // null = ilimitado
  timesUsed       Int       @default(0)

  // Restrições (arrays vazios = sem restrição)
  appliesToPlans  String[]  @default([])
  appliesToCycles String[]  @default([])

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions     CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id                  String   @id @default(uuid())
  couponId            String
  coupon              Coupon   @relation(fields: [couponId], references: [id])
  userId              String   // Logto sub (logtoId)
  userEmail           String?
  planId              String
  cycle               String   // MONTHLY | YEARLY
  originalValue       Decimal  @db.Decimal(10, 2)
  discountValue       Decimal  @db.Decimal(10, 2)
  finalValue          Decimal  @db.Decimal(10, 2)
  asaasSubscriptionId String?
  redeemedAt          DateTime @default(now())

  @@index([userId])
  @@index([couponId])
  @@map("coupon_redemptions")
}

model UserSettings {
  orgId String @id

  /// Intervalo aleatório entre envios (ms), padrão alinhado ao anti-spam básico
  campaignJitterMinMs Int @default(900)
  campaignJitterMaxMs Int @default(2200)

  /// Variantes de texto (com {{name}}, {{phone}}). Se useMessageVariants=true, sorteia A/B/C preenchidas.
  messageVariantA     String?
  messageVariantB     String?
  messageVariantC     String?
  useMessageVariants Boolean @default(false)

  /// Lista JSON de IPs permitidos (strings exatas). Vazio = sem restrição.
  ipAllowlist String?

  /// Quando true, chamadas com API key (sk_) exigem header Client-Token.
  requireClientToken Boolean @default(false)
  clientTokenHash    String?

  bulkMessagingTermsAcceptedAt DateTime?

  updatedAt DateTime @updatedAt

  @@map("user_settings")
}
