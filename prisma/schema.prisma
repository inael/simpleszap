generator client {
  provider      = "prisma-client-js"
  output        = "../apps/api/node_modules/.prisma/client"
  // native = OS do dev (Windows/macOS/Linux local). rhel-openssl-3.0.x = AWS Lambda
  // do Vercel. Sem o RHEL aqui, `vercel deploy --prebuilt` empacotava so o engine
  // do Windows -> PrismaClientInitializationError em prod (jun/2026).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  logtoId           String   @unique
  email             String   @unique
  name              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  subscriptionPlanId String?
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  trialEndsAt        DateTime?
  asaasCustomerId   String?
  cpfCnpj           String?

  // Cortesia VIP (bypass Asaas) — admin concede plano por N meses sem cobrar.
  // Quando manualSubscriptionUntil > now, enforcement usa o plano linkado em
  // subscriptionPlanId ignorando trialEndsAt e asaasCustomerId.
  manualSubscriptionUntil DateTime?
  manualPlanReason        String?

  emailQueue              EmailQueue[]

  instances         Instance[]
  apiKeys           ApiKey[]
  dailyUsages       DailyUsage[]
  betaFeatureAcceptances BetaFeatureAcceptance[]
  messageAddons          MessageAddon[]
}

/// Fila de saída de mensagens. Todo POST /message/sendText e /sendButtons
/// enfileira aqui em vez de enviar inline — garante ordem FIFO por instância,
/// jitter aleatório (configurado em UserSettings) e visibilidade pro user.
/// Cron /cron/process-message-queue roda a cada 1min e processa rows com
/// scheduledAt <= now, em ordem cronológica por instância. Sem retry: msg
/// falhada não tenta de novo (evita enviar fora de contexto numa conversa).
model OutboundMessageQueue {
  id            String   @id @default(uuid())
  orgId         String
  instanceId    String
  /// "text" | "buttons" | (futuro: image, audio, document)
  type          String   @default("text")
  /// E.164 normalizado (sem '+'). Ex: 5511999999999
  number        String
  /// Texto da mensagem (pra type=text)
  body          String?
  /// Payload completo enviado pelo cliente (pra type=buttons e outros)
  payload       Json?
  /// Quando o worker deve processar (now + jitter cumulativo da fila da instância)
  scheduledAt   DateTime
  /// pending | processing | sent | failed | cancelled | skipped_limit
  status        String   @default("pending")
  sentAt        DateTime?
  /// Mensagem de erro do Evolution quando falha (sem retry)
  lastError     String?
  attempts      Int      @default(0)
  /// FK opcional pra campanha (quando enfileirado via run de campanha)
  campaignId    String?
  /// FK opcional pra ApiKey (rastrear origem de envios via API)
  apiKeyId      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId, status])
  @@index([instanceId, status, scheduledAt])
  @@index([status, scheduledAt])
  @@map("outbound_message_queue")
}

/// Aceitação de features beta com termos de uso. Cada user aceita por
/// feature (`featureKey`) uma versão específica do termo. Usado pra liberar
/// endpoints como POST /message/sendButtons (botões interativos do WhatsApp
/// — entrega errática por restrição da Meta, exige aceitação explícita).
model BetaFeatureAcceptance {
  id           String    @id @default(uuid())
  userId       String
  featureKey   String
  termsVersion String
  acceptedAt   DateTime  @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@map("beta_feature_acceptances")
}

model SubscriptionPlan {
  id                String   @id // 'free', 'basic', 'pro', 'enterprise'
  name              String
  description       String?
  priceMonthly      Decimal  @db.Decimal(10, 2) @default(0)
  priceAnnual       Decimal  @db.Decimal(10, 2) @default(0)
  
  // Limits
  messagesPerDay    Int      @default(100)
  instancesLimit    Int      @default(1)
  
  // Features
  hasWebhooks       Boolean  @default(false)
  hasTemplates      Boolean  @default(false)
  hasSmsIncluded    Boolean  @default(false)
  
  // Payment
  asaasId           String? // ID do produto no Asaas
  
  isActive          Boolean  @default(true)
  /// Quando false, o plano não aparece na listagem pública (/pricing).
  /// Usado pra planos internos IT Booster (cortesia, integrações) que existem
  /// pro enforcement mas não devem ser vendidos.
  isPublic          Boolean  @default(true)
  displayOrder      Int      @default(0)
  
  users             User[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("subscription_plans")
}

model Instance {
  id                    String   @id @default(uuid())
  name                  String   // nome exibido ao usuário (livre, pode ter espaços/acentos)
  evolutionInstanceName String?  // nome enviado à Evolution API: simpleszap_<slug>_<8chars>
  /// Numero WhatsApp em E.164 BR (sem +). Informado pelo user no form Nova
  /// Instancia e usado pra bloquear duplicata entre tenants (mesmo numero em
  /// 2 contas SimplesZap). Sobrescrito pelo numero real (ownerJid) quando o
  /// webhook CONNECTION_UPDATE da Evolution chega pareando.
  phoneNumber           String?
  status                String   @default("disconnected") // disconnected, connecting, connected
  serverUrl             String?  // URL da Evolution API para esta instancia (se multi-server)
  token                 String?  // Token da Evolution API
  orgId                 String?

  /// Token único pra link público de pareamento (sem auth). Quando setado e
  /// não expirado, GET /public/connect/:token retorna o QR sem autenticação.
  /// Limpo automaticamente quando a instância conecta (status=open) ou ao expirar.
  publicConnectToken          String?   @unique
  publicConnectTokenExpiresAt DateTime?

  // ===== Pricing por instância (modelo elástico, 2026-05) =====
  /// Status da assinatura Asaas pra essa instância. active = paga em dia.
  /// pending = checkout criado mas não confirmou pagamento. canceled = cliente
  /// cancelou. past_due = inadimplente. null = grátis (Free, 1 instância só).
  subscriptionStatus    String?
  /// ID da subscription no Asaas (externalReference no Asaas é "instance:<id>")
  asaasSubscriptionId   String?   @unique
  /// Quando o pagamento atual termina (próximo vencimento Asaas).
  paidUntil             DateTime?
  /// Preço mensal cobrado por essa instância em centavos. Default 5900 = R$59.
  pricePerMonthCents    Int       @default(5900)
  /// Mensagens incluídas por dia nessa instância (cap próprio antes do pool global).
  messagesIncluded      Int       @default(300)

  userId                String
  user                  User     @relation(fields: [userId], references: [id])

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

/// Contador diário de mensagens enviadas POR INSTÂNCIA. Usado pelo enforcement
/// novo: cada instância tem seu próprio cap (messagesIncluded). Quando estoura,
/// usa o pool global da conta (somado de todos os MessageAddon active).
model InstanceDailyUsage {
  id         String   @id @default(uuid())
  instanceId String
  date       DateTime @db.Date
  count      Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([instanceId, date])
  @@map("instance_daily_usage")
}

/// Add-on de mensagens — cliente compra lotes extras que vão pra um POOL global
/// da conta. Quando uma instância estoura messagesIncluded, consome desse pool
/// (somado de todas as instâncias da conta). 1 lote = +100 msgs/dia pelo preço
/// padrão (1500¢ = R$15). Cliente pode ter quantos lotes quiser.
model MessageAddon {
  id                  String   @id @default(uuid())
  userId              String
  /// active = pagando, canceled = cancelado, past_due = inadimplente, pending = checkout aberto
  status              String   @default("pending")
  asaasSubscriptionId String?  @unique
  messagesPerDay      Int      @default(100)
  pricePerMonthCents  Int      @default(1500)
  paidUntil           DateTime?
  cancelledAt         DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("message_addons")
}

model ApiKey {
  id                String   @id @default(uuid())
  key               String   @unique
  name              String?
  orgId             String?
  scopes            String?
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  createdAt         DateTime @default(now())
  expiresAt         DateTime?
}

model DailyUsage {
  id        String   @id @default(uuid())
  orgId     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @db.Date // Store only the date part
  count     Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("daily_usages")
}

model WebhookConfig {
  id         String   @id @default(uuid())
  orgId      String
  // Override por instância (estilo Stripe/Twilio): null = config global da org
  // (recebe eventos de todas as instâncias). Quando preenchido, sobrescreve
  // o global para aquela instância específica em WebhookDeliveryService.trigger.
  instanceId String?
  url        String
  events     String   // JSON array of event names
  secret     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId, instanceId])
}

model WebhookLog {
  id         String   @id @default(uuid())
  orgId      String
  webhookId  String
  event      String
  payload    String
  success    Boolean
  statusCode Int?
  error      String?
  createdAt  DateTime @default(now())
}

model Campaign {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  instanceId  String
  templateId  String?
  segmentTags String?  // JSON array of tags (filtro alternativo, legacy)
  /// JSON array de Contact.id selecionados pelo user. Quando preenchido,
  /// campaign.run usa essa lista exata (ignora segmentTags). Quando null/[],
  /// cai no comportamento legacy de filtrar Contact por segmentTags.
  contactIds  String?
  scheduledAt DateTime?
  status      String   @default("draft") // draft, scheduled, running, done
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  data      String?
  createdAt DateTime @default(now())
}
model Message {
  id          String   @id @default(uuid())
  orgId       String
  instanceId  String
  /// DEPRECATED — mantido por backward-compat. Era ambíguo (significava
  /// "destinatário" em sent e "remetente" em received). Bots novos devem
  /// usar `toNumber` e `fromNumber` (que são explícitos por direção).
  /// Preenchimento atual: igual ao "outro lado" (mesmo que sempre foi).
  to          String
  /// Destinatário da mensagem. Preenchido em direction=sent; NULL em received.
  toNumber    String?
  /// Remetente da mensagem. Preenchido em direction=received; NULL em sent.
  fromNumber  String?
  body        String
  /// text | image | audio | video | document | location | buttons | reaction
  type        String   @default("text")
  /// queued | sent | delivered | read | failed | received
  status      String   @default("queued")
  /// sent (saída, nós enviamos) | received (entrada, lead/contato mandou pra gente)
  direction   String   @default("sent")
  /// ID original da mensagem no WhatsApp (whatsapp.net key.id). Usado pra dedup.
  whatsappMessageId String? @unique
  /// URL do anexo (audio/image/video/document), quando type != text
  mediaUrl    String?
  /// Nome do contato (se disponível via webhook Evolution)
  fromName    String?
  /// Se essa msg é resposta a outra, ID da msg citada
  quotedMessageId String?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, direction, createdAt])
  @@index([instanceId, createdAt])
}

model Template {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  /// Texto principal (igual variantA, mantido pra leitura legacy e fallback)
  body      String
  /// 3 variantes obrigatórias (anti-banimento WhatsApp/Meta).
  /// Validação backend: trim() != "" e todas DIFERENTES entre si (case-sensitive).
  /// Quando uma campanha roda, sistema sorteia entre A/B/C por mensagem.
  variantA  String
  variantB  String
  variantC  String
  variables String?  // JSON array of variable names (legacy)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  orgId     String
  name      String?
  phone     String   @unique
  tags      String?  // JSON array of strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt     @map("updated_at")

  @@map("system_settings")
}

/// Preferências por organização (x-org-id = logto sub). Usado em envio em massa e segurança da API.
model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?

  // Tipo de desconto: ou percentOff (0-100) ou amountOff (R$ fixo). Apenas um.
  percentOff      Int?
  amountOff       Decimal? @db.Decimal(10, 2)

  // Validade
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  maxUses         Int?      // null = ilimitado
  timesUsed       Int       @default(0)

  // Restrições (arrays vazios = sem restrição)
  appliesToPlans  String[]  @default([])
  appliesToCycles String[]  @default([])

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions     CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id                  String   @id @default(uuid())
  couponId            String
  coupon              Coupon   @relation(fields: [couponId], references: [id])
  userId              String   // Logto sub (logtoId)
  userEmail           String?
  planId              String
  cycle               String   // MONTHLY | YEARLY
  originalValue       Decimal  @db.Decimal(10, 2)
  discountValue       Decimal  @db.Decimal(10, 2)
  finalValue          Decimal  @db.Decimal(10, 2)
  asaasSubscriptionId String?
  redeemedAt          DateTime @default(now())

  @@index([userId])
  @@index([couponId])
  @@map("coupon_redemptions")
}

model UserSettings {
  orgId String @id

  /// Intervalo aleatório entre envios (ms), padrão alinhado ao anti-spam básico
  campaignJitterMinMs Int @default(900)
  campaignJitterMaxMs Int @default(2200)

  /// Variantes de texto (com {{name}}, {{phone}}). Se useMessageVariants=true, sorteia A/B/C preenchidas.
  messageVariantA     String?
  messageVariantB     String?
  messageVariantC     String?
  useMessageVariants Boolean @default(false)

  /// Lista JSON de IPs permitidos (strings exatas). Vazio = sem restrição.
  ipAllowlist String?

  /// Quando true, chamadas com API key (sk_) exigem header Client-Token.
  requireClientToken Boolean @default(false)
  clientTokenHash    String?

  bulkMessagingTermsAcceptedAt DateTime?

  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// Fila de emails transacionais (onboarding, win-back, alertas).
// Cron diário processa rows com status=pending e sendAt<=now (até maxAttempts).
// userId aqui é User.id (não logtoId) — relation pra facilitar joins.
model EmailQueue {
  id        Int      @id @default(autoincrement())
  userId    String
  userEmail String
  template  String   // ex: 'onboarding_d0', 'winback_d3', 'trial_ending'
  sendAt    DateTime
  sentAt    DateTime?
  status    String   @default("pending") // pending | sent | failed | skipped
  attempts  Int      @default(0)
  error     String?
  payload   Json?    // dados arbitrários consumidos pelo template
  messageId String?  // id retornado pelo SimplesMail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
  @@index([userId, template])
  @@map("EmailQueue")
}
